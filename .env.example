# Operácia Kopanice — environment configuration
# Copy to `.env` (or set in your Vercel project) and fill in the values you need.
# Everything is optional: with no config the game uses local saves and the
# offline tactical advisor.

# --- Cloud sync: Firebase Realtime Database -------------------------------
# When VITE_FIREBASE_API_KEY and VITE_FIREBASE_DATABASE_URL are both set, the
# game syncs saves to Firebase (loaded lazily from the CDN). Otherwise it falls
# back to localStorage. These are client-exposed (VITE_*) — use a database whose
# rules restrict access appropriately.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# Save slot key (lets multiple profiles share one database).
VITE_SAVE_SLOT=default

# --- Claude Code assistant -------------------------------------------------
# URL of the serverless assistant endpoint (see api/assistant.ts). When set, the
# in-game advisor (press H) is answered by Claude; otherwise the deterministic
# local advisor is used. On Vercel this is simply /api/assistant.
VITE_ASSISTANT_ENDPOINT=

# --- Server-side only (NOT exposed to the browser) -------------------------
# Used by api/assistant.ts. Never prefix these with VITE_.
ANTHROPIC_API_KEY=
# Optional model override for the assistant endpoint.
ANTHROPIC_MODEL=
# Optional abuse guard: comma-separated allowed Origin values for /api/assistant.
# When set, requests from other origins are rejected (403). Unset = no check.
ASSISTANT_ALLOWED_ORIGINS=
