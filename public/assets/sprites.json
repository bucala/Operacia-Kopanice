{
  "$schema": "./schema/sprites.schema.json",
  "description": "Sprite + prop atlas. Characters render procedurally (layered isometric shapes) and, when the optional `image` file is present under public/assets, as that high-fidelity render instead. `props` are image-only (buildings, crates, decorations). All `anchorX/anchorY` are 0..1 pivots on the tile; `scale` is drawn width in tile-widths. See docs/ASSETS.md for the source images and tuning.",
  "sprites": {
    "agent": {
      "kind": "character",
      "bodyHeight": 30,
      "radius": 9,
      "palette": {
        "body": "#3b7dd8",
        "bodyDark": "#27568f",
        "head": "#e3b793",
        "headDark": "#b98c6b",
        "accent": "#9ae6b4",
        "outline": "#0b1320"
      },
      "image": { "src": "sprites/agent.png", "anchorX": 0.5, "anchorY": 0.92, "scale": 1.5 }
    },
    "agent_disguised": {
      "kind": "character",
      "bodyHeight": 30,
      "radius": 9,
      "palette": {
        "body": "#7a2f2f",
        "bodyDark": "#511f1f",
        "head": "#e3b793",
        "headDark": "#b98c6b",
        "accent": "#d8c27a",
        "outline": "#0b1320"
      },
      "image": { "src": "sprites/agent_disguised.png", "anchorX": 0.5, "anchorY": 0.92, "scale": 1.5 }
    },
    "guard": {
      "kind": "character",
      "bodyHeight": 30,
      "radius": 9,
      "palette": {
        "body": "#9b2c2c",
        "bodyDark": "#6b1d1d",
        "head": "#d9a77f",
        "headDark": "#a87b58",
        "accent": "#e2c044",
        "outline": "#0b1320"
      },
      "image": { "src": "sprites/guard.png", "anchorX": 0.5, "anchorY": 0.92, "scale": 1.5 }
    }
  },
  "props": {
    "cottage": {
      "src": "sprites/cottage.png",
      "anchorX": 0.5,
      "anchorY": 0.84,
      "scale": 4.2,
      "layer": "object"
    },
    "tnt_crate": {
      "src": "sprites/tnt_crate.png",
      "anchorX": 0.5,
      "anchorY": 0.78,
      "scale": 1.3,
      "layer": "object"
    },
    "decor_conifer": {
      "src": "sprites/decor/conifer.png",
      "anchorX": 0.5,
      "anchorY": 0.95,
      "scale": 1.7,
      "layer": "object"
    },
    "decor_boulder": {
      "src": "sprites/decor/boulder.png",
      "anchorX": 0.5,
      "anchorY": 0.86,
      "scale": 1.4,
      "layer": "object"
    },
    "decor_haystack": {
      "src": "sprites/decor/haystack.png",
      "anchorX": 0.5,
      "anchorY": 0.86,
      "scale": 1.2,
      "layer": "object"
    }
  }
}
